#!/bin/sh

set -eu

CONFIG="cf_ip_speed_client"
SECTION="main"
WORKER_URL="https://cf.6610000.xyz"
WORKDIR="/tmp/cf-ip-speed-client"
PAYLOAD="${WORKDIR}/upload.json"
LOG_FILE="/tmp/cf-ip-speed-client.log"
CFST_LOG="/tmp/cf-ip-speed-client-cfst.log"
IP_FILE="/etc/cf-ip-speed-client/ip.txt"
IP_V6_FILE="/etc/cf-ip-speed-client/ip-v6.txt"
PROXY_STATE_FILE="/tmp/cf-ip-speed-client-proxy-services"
LOCK_DIR="/tmp/cf-ip-speed-client.lock"
BACKGROUND_LOG="/tmp/cf-ip-speed-client-background.log"
BACKGROUND_PID="/tmp/cf-ip-speed-client-background.pid"
DEFAULT_DOWNLOAD_URL="${WORKER_URL}/__speedtest?bytes=104857600"
CFST_STABLE_ARGS="-n 60 -t 4 -dn 8 -dt 15 -tlr 0 -p 8"
PROXY_SERVICES="nikki openclash passwall passwall2 passwall_server passwall2_server homeproxy shadowsocksr shadowsocks-libev momo sing-box mihomo clash v2raya xray luci-xray nekobox fullcombo fullcombo-shark"

log() {
	logger -t cf-ip-speed-client "$*"
	echo "$*" >> "$LOG_FILE"
	trim_log_file "$LOG_FILE"
}

set_status() {
	uci set "${CONFIG}.${SECTION}.last_status=$1"
	uci set "${CONFIG}.${SECTION}.last_message=$2"
	uci set "${CONFIG}.${SECTION}.last_upload_at=$(TZ=CST-8 date '+%Y-%m-%d %H:%M:%S CST')"
	uci commit "$CONFIG"
}

cfg() {
	uci -q get "${CONFIG}.${SECTION}.$1" 2>/dev/null || echo "${2:-}"
}

log_max_size() {
	size="$(cfg log_max_size 1048576 | sed 's/[^0-9]//g')"
	[ -n "$size" ] || size=1048576
	if [ "$size" -lt 10240 ] 2>/dev/null; then
		size=10240
	fi
	echo "$size"
}

trim_log_file() {
	file="$1"
	[ -f "$file" ] || return 0
	limit="$(log_max_size)"
	current_size="$(wc -c < "$file" 2>/dev/null || echo 0)"
	if [ "$current_size" -le "$limit" ] 2>/dev/null; then
		return 0
	fi
	tmp="${file}.tmp"
	tail -c "$limit" "$file" > "$tmp" 2>/dev/null && mv "$tmp" "$file"
}

clear_logs() {
	: > "$LOG_FILE"
	: > "$BACKGROUND_LOG"
	: > "$CFST_LOG"
	set_status "ok" "日志已清空"
	echo "logs cleared"
}

show_logs() {
	for file in "$LOG_FILE" "$BACKGROUND_LOG" "$CFST_LOG"; do
		trim_log_file "$file"
	done
	echo "===== cf-ip-speed-client.log ====="
	if [ -f "$LOG_FILE" ]; then cat "$LOG_FILE"; else echo "(empty)"; fi
	echo
	echo "===== cf-ip-speed-client-background.log ====="
	if [ -f "$BACKGROUND_LOG" ]; then cat "$BACKGROUND_LOG"; else echo "(empty)"; fi
	echo
	echo "===== cf-ip-speed-client-cfst.log ====="
	if [ -f "$CFST_LOG" ]; then cat "$CFST_LOG"; else echo "(empty)"; fi
}

get_hostname() {
	cat /proc/sys/kernel/hostname 2>/dev/null || hostname 2>/dev/null || echo openwrt
}

json_escape() {
	sed 's/\\/\\\\/g; s/"/\\"/g' | tr -d '\r'
}

require_command() {
	if ! command -v "$1" >/dev/null 2>&1; then
		case "$1" in
			cfst)
				set_status "error" "缺少 cfst，请重新运行一键安装脚本，或手动安装 CloudflareSpeedTest 后重试。"
				;;
			*)
				set_status "error" "缺少命令：$1"
				;;
		esac
		log "ERROR: missing command: $1"
		exit 1
	fi
}

stop_active_proxy_services() {
	: > "$PROXY_STATE_FILE"
	for service in $PROXY_SERVICES; do
		if [ -x "/etc/init.d/$service" ] && proxy_service_is_active "$service"; then
			echo "$service" >> "$PROXY_STATE_FILE"
			log "stopping proxy service before test: $service"
			"/etc/init.d/$service" stop >/dev/null 2>&1 || true
		fi
	done
	if [ -s "$PROXY_STATE_FILE" ]; then
		sleep 3
	fi
}

proxy_service_is_active() {
	service="$1"
	status_output="$("/etc/init.d/$service" status 2>&1 || true)"
	case "$status_output" in
		running|active)
			return 0
			;;
	esac

	case "$service" in
		nikki) process_pattern="/etc/nikki/run" ;;
		openclash) process_pattern="/etc/openclash" ;;
		passwall) process_pattern="/tmp/etc/passwall/" ;;
		passwall2) process_pattern="/tmp/etc/passwall2/" ;;
		passwall_server) process_pattern="/tmp/etc/passwall_server/" ;;
		passwall2_server) process_pattern="/tmp/etc/passwall2_server/" ;;
		homeproxy) process_pattern="/var/run/homeproxy/" ;;
		shadowsocksr) process_pattern="/var/etc/shadowsocksr/" ;;
		shadowsocks-libev) process_pattern="ss-redir" ;;
		momo) process_pattern="/etc/momo/" ;;
		sing-box) process_pattern="sing-box run" ;;
		mihomo) process_pattern="/usr/bin/mihomo" ;;
		clash) process_pattern="/usr/bin/clash" ;;
		v2raya) process_pattern="v2rayA" ;;
		xray|luci-xray) process_pattern="/usr/bin/xray" ;;
		nekobox) process_pattern="nekobox" ;;
		fullcombo|fullcombo-shark) process_pattern="fullcombo" ;;
		*) return 1 ;;
	esac

	ps ww 2>/dev/null | grep -F "$process_pattern" | grep -v grep >/dev/null 2>&1
}

restore_proxy_services() {
	if [ ! -f "$PROXY_STATE_FILE" ]; then
		return 0
	fi
	while IFS= read -r service; do
		[ -n "$service" ] || continue
		if [ -x "/etc/init.d/$service" ]; then
			log "restoring proxy service after test: $service"
			"/etc/init.d/$service" start >/dev/null 2>&1 || true
		fi
	done < "$PROXY_STATE_FILE"
	rm -f "$PROXY_STATE_FILE"
}

cleanup_run() {
	restore_proxy_services
	rm -f "$LOCK_DIR/pid"
	rmdir "$LOCK_DIR" 2>/dev/null || true
}

recover_stale_run() {
	[ -d "$LOCK_DIR" ] || return 0
	lock_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
	if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
		return 1
	fi
	log "recovering stale test lock"
	restore_proxy_services
	rm -f "$LOCK_DIR/pid"
	rmdir "$LOCK_DIR" 2>/dev/null || true
	return 0
}

stopped_proxy_summary() {
	if [ -s "$PROXY_STATE_FILE" ]; then
		tr '\n' ' ' < "$PROXY_STATE_FILE" | sed 's/[[:space:]]*$//'
	fi
}

register_device() {
	nickname="$(cfg nickname)"
	device_id="$(cfg device_id)"
	device_token="$(cfg device_token)"
	device_name="$(get_hostname)"

	if [ -n "$device_id" ] && [ -n "$device_token" ]; then
		set_status "ok" "已注册。如需更换昵称，请先清空设备凭据后重新注册。"
		echo "already registered: $device_id"
		return 0
	fi
	if [ -z "$nickname" ]; then
		set_status "error" "请先填写昵称"
		exit 1
	fi

	response="$(curl -fsS -X POST "${WORKER_URL}/api/public/register" \
		-H "Content-Type: application/json" \
		-d "{\"nickname\":\"$(printf '%s' "$nickname" | json_escape)\",\"device_name\":\"$(printf '%s' "$device_name" | json_escape)\"}")"

	device_id="$(printf '%s' "$response" | jsonfilter -e '@.device_id' 2>/dev/null || true)"
	device_token="$(printf '%s' "$response" | jsonfilter -e '@.device_token' 2>/dev/null || true)"
	if [ -z "$device_id" ] || [ -z "$device_token" ]; then
		set_status "error" "注册失败：$response"
		exit 1
	fi

	uci set "${CONFIG}.${SECTION}.device_id=$device_id"
	uci set "${CONFIG}.${SECTION}.device_token=$device_token"
	uci commit "$CONFIG"
	set_status "ok" "注册成功"
	echo "registered: $device_id"
}

default_interface() {
	ip_version="${1:-v4}"
	if [ "$ip_version" = "v6" ]; then
		ip -6 route show default 2>/dev/null | awk '{ for (i=1; i<=NF; i++) if ($i=="dev") { print $(i+1); exit } }'
	else
		ip route show default 2>/dev/null | awk '{ for (i=1; i<=NF; i++) if ($i=="dev") { print $(i+1); exit } }'
	fi
}

ipv6_source_address() {
	interface="$1"
	[ -n "$interface" ] || return 0
	ip -6 addr show dev "$interface" scope global 2>/dev/null |
		awk '/inet6 / { split($2, address, "/"); print address[1]; exit }'
}

detect_direct() {
	target_ip="$1"
	ip_version="${2:-v4}"
	default_if="$(default_interface "$ip_version")"
	if [ "$ip_version" = "v6" ]; then
		ipv6_source="$(ipv6_source_address "$default_if")"
		if [ -n "$ipv6_source" ]; then
			route_interface="$(ip -6 route get "$target_ip" from "$ipv6_source" 2>/dev/null | awk '{ for (i=1; i<=NF; i++) if ($i=="dev") { print $(i+1); exit } }')"
		else
			route_interface="$(ip -6 route get "$target_ip" 2>/dev/null | awk '{ for (i=1; i<=NF; i++) if ($i=="dev") { print $(i+1); exit } }')"
		fi
		curl_family="-6"
	else
		route_interface="$(ip route get "$target_ip" 2>/dev/null | awk '{ for (i=1; i<=NF; i++) if ($i=="dev") { print $(i+1); exit } }')"
		curl_family="-4"
	fi
	if [ -z "$route_interface" ]; then
		route_interface="$default_if"
	fi

	if [ "$ip_version" = "v6" ] && [ -n "${ipv6_source:-}" ]; then
		egress_meta="$(curl "$curl_family" --interface "$ipv6_source" -fsS --max-time 8 https://ipinfo.io/json 2>/dev/null || true)"
	else
		egress_meta="$(curl "$curl_family" -fsS --max-time 8 https://ipinfo.io/json 2>/dev/null || true)"
	fi
	egress_ip="$(printf '%s' "$egress_meta" | jsonfilter -e '@.ip' 2>/dev/null || true)"
	egress_region="$(printf '%s' "$egress_meta" | jsonfilter -e '@.region' 2>/dev/null || true)"
	egress_city="$(printf '%s' "$egress_meta" | jsonfilter -e '@.city' 2>/dev/null || true)"
	egress_country="$(printf '%s' "$egress_meta" | jsonfilter -e '@.country' 2>/dev/null || true)"
	egress_org="$(printf '%s' "$egress_meta" | jsonfilter -e '@.org' 2>/dev/null || true)"
	egress_asn="$(printf '%s' "$egress_org" | sed -n 's/^AS\([0-9][0-9]*\).*/\1/p')"
	if [ -z "$egress_ip" ]; then
		if [ "$ip_version" = "v6" ]; then
			if [ -n "${ipv6_source:-}" ]; then
				egress_ip="$(curl -6 --interface "$ipv6_source" -fsS --max-time 8 https://api6.ipify.org 2>/dev/null || true)"
			else
				egress_ip="$(curl -6 -fsS --max-time 8 https://api6.ipify.org 2>/dev/null || true)"
			fi
		else
			egress_ip="$(curl -4 -fsS --max-time 8 https://api.ipify.org 2>/dev/null || true)"
		fi
	fi

	warnings=""
	proxy_suspected="false"

	case "$route_interface" in
		tun*|utun*|clash*|mihomo*|sing-box*|wg*|tailscale*|zerotier*|nikki*)
			proxy_suspected="true"
			warnings="路由出口疑似代理接口"
			;;
	esac
	if [ -n "$default_if" ] && [ -n "$route_interface" ] && [ "$route_interface" != "$default_if" ]; then
		proxy_suspected="true"
		warnings="${warnings}${warnings:+; }测速路由出口不是默认出口"
	fi
	if printf '%s' "$egress_org" | grep -Eiq 'alibaba|amazon|aws|google|microsoft|azure|cloudflare|tencent|huawei|oracle|digitalocean|linode|akamai|vultr|hetzner|ovh|cloud|hosting|data center|datacenter'; then
		proxy_suspected="true"
		warnings="${warnings}${warnings:+; }出口 ASN 疑似云服务或代理"
	fi
	if [ -n "$egress_country" ] && [ "$egress_country" != "CN" ]; then
		proxy_suspected="true"
		warnings="${warnings}${warnings:+; }出口国家不是 CN"
	fi

	if [ -n "$warnings" ]; then
		warnings_json="[\"$(printf '%s' "$warnings" | json_escape)\"]"
	else
		warnings_json="[]"
	fi

	printf '{"proxy_suspected":%s,"route_interface":"%s","wan_interface":"%s","egress_ip":"%s","egress_asn":"%s","egress_country":"%s","egress_org":"%s","egress_region":"%s","egress_city":"%s","warnings":%s}' \
		"$proxy_suspected" \
		"$(printf '%s' "$route_interface" | json_escape)" \
		"$(printf '%s' "$default_if" | json_escape)" \
		"$(printf '%s' "$egress_ip" | json_escape)" \
		"$(printf '%s' "$egress_asn" | json_escape)" \
		"$(printf '%s' "$egress_country" | json_escape)" \
		"$(printf '%s' "$egress_org" | json_escape)" \
		"$(printf '%s' "$egress_region" | json_escape)" \
		"$(printf '%s' "$egress_city" | json_escape)" \
		"$warnings_json"
}

csv_to_nodes() {
	result_file="$1"
	awk -F',' '
	NR == 1 {
		for (i = 1; i <= NF; i++) {
			gsub(/^\xef\xbb\xbf/, "", $i)
			h = tolower($i)
			if (h ~ /ip/) ip_col = i
			if (h ~ /port|端口/) port_col = i
			if (h ~ /latency|平均延迟/) lat_col = i
			if (h ~ /speed|下载速度/) speed_col = i
			if (h ~ /loss|丢包率/) loss_col = i
			if (h ~ /colo|地区码|数据中心/) colo_col = i
		}
		if (!ip_col && NF >= 7) ip_col = 1
		if (!loss_col && NF >= 7) loss_col = 4
		if (!lat_col && NF >= 7) lat_col = 5
		if (!speed_col && NF >= 7) speed_col = 6
		if (!colo_col && NF >= 7) colo_col = 7
		next
	}
	ip_col && $ip_col != "" {
		ip = $ip_col
		port = port_col ? $port_col : 443
		lat = lat_col ? $lat_col : 0
		speed = speed_col ? $speed_col : 0
		loss = loss_col ? $loss_col : 0
		colo = colo_col ? $colo_col : ""
		gsub(/[^0-9.]/, "", port)
		gsub(/[^0-9.]/, "", lat)
		gsub(/[^0-9.]/, "", speed)
		gsub(/[^0-9.]/, "", loss)
		gsub(/"/, "\\\"", ip)
		gsub(/"/, "\\\"", colo)
		printf "%s{\"ip\":\"%s\",\"port\":%s,\"latency\":%s,\"speed\":%s,\"loss\":%s,\"tls\":true,\"colo\":\"%s\"}", sep, ip, port ? port : 443, lat ? lat : 0, speed ? speed : 0, loss ? loss : 0, colo
		sep=","
	}' "$result_file"
}

best_node_fields() {
	result_file="$1"
	awk -F',' '
	function trim(value) {
		gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
		return value
	}
	NR == 1 {
		for (i = 1; i <= NF; i++) {
			gsub(/^\xef\xbb\xbf/, "", $i)
			h = tolower($i)
			if (h ~ /ip/) ip_col = i
			if (h ~ /port|端口/) port_col = i
			if (h ~ /latency|平均延迟/) lat_col = i
			if (h ~ /speed|下载速度/) speed_col = i
			if (h ~ /loss|丢包率/) loss_col = i
			if (h ~ /colo|地区码|数据中心/) colo_col = i
		}
		if (!ip_col && NF >= 7) ip_col = 1
		if (!loss_col && NF >= 7) loss_col = 4
		if (!lat_col && NF >= 7) lat_col = 5
		if (!speed_col && NF >= 7) speed_col = 6
		if (!colo_col && NF >= 7) colo_col = 7
		next
	}
	ip_col && $ip_col != "" {
		ip = trim($ip_col)
		port = port_col ? trim($port_col) : 443
		lat = lat_col ? trim($lat_col) : 0
		speed = speed_col ? trim($speed_col) : 0
		loss = loss_col ? trim($loss_col) : 0
		colo = colo_col ? trim($colo_col) : ""
		gsub(/[^0-9.]/, "", port)
		gsub(/[^0-9.]/, "", lat)
		gsub(/[^0-9.]/, "", speed)
		gsub(/[^0-9.]/, "", loss)
		gsub(/[^A-Za-z0-9_-]/, "", colo)
		printf "%s\t%s\t%s\t%s\t%s\t%s\n", ip, port ? port : 443, lat ? lat : 0, speed ? speed : 0, loss ? loss : 0, colo
		exit
	}' "$result_file"
}

ip_file_for_version() {
	case "$1" in
		v6) echo "$IP_V6_FILE" ;;
		*) echo "$IP_FILE" ;;
	esac
}

result_file_for_version() {
	configured_result_file="$1"
	ip_version="$2"
	if [ "$ip_version" = "v4" ]; then
		echo "$configured_result_file"
		return 0
	fi
	case "$configured_result_file" in
		*.csv) echo "${configured_result_file%.csv}-v6.csv" ;;
		*) echo "${configured_result_file}-v6" ;;
	esac
}

has_ipv6_route() {
	default_if="$(default_interface v6)"
	ipv6_source="$(ipv6_source_address "$default_if")"
	if [ -n "$ipv6_source" ]; then
		ip -6 route get 2606:4700::6810:85e5 from "$ipv6_source" >/dev/null 2>&1
	else
		ip -6 route get 2606:4700::6810:85e5 >/dev/null 2>&1
	fi
}

version_label() {
	if [ "$1" = "v6" ]; then
		echo "IPv6"
	else
		echo "IPv4"
	fi
}

append_summary() {
	if [ -n "$RESULT_SUMMARY" ]; then
		RESULT_SUMMARY="${RESULT_SUMMARY}；$1"
	else
		RESULT_SUMMARY="$1"
	fi
}

clear_result_state() {
	for ip_version in v4 v6; do
		for field in ip port speed latency loss colo result_file route_interface egress_ip proxy_suspected warning updated_at record_type; do
			uci -q delete "${CONFIG}.${SECTION}.last_result_${ip_version}_${field}" 2>/dev/null || true
		done
	done
	uci commit "$CONFIG"
}

save_result_state() {
	ip_version="$1"
	result_file="$2"
	direct_check="$3"
	best_fields="$(best_node_fields "$result_file" || true)"
	[ -n "$best_fields" ] || return 0

	old_ifs="$IFS"
	IFS="$(printf '\t')"
	read -r best_ip best_port best_latency best_speed best_loss best_colo <<EOF
$best_fields
EOF
	IFS="$old_ifs"

	if [ "$ip_version" = "v6" ]; then
		record_type="AAAA"
	else
		record_type="A"
	fi
	proxy_suspected="$(printf '%s' "$direct_check" | jsonfilter -e '@.proxy_suspected' 2>/dev/null || true)"
	route_interface="$(printf '%s' "$direct_check" | jsonfilter -e '@.route_interface' 2>/dev/null || true)"
	egress_ip="$(printf '%s' "$direct_check" | jsonfilter -e '@.egress_ip' 2>/dev/null || true)"
	warning="$(printf '%s' "$direct_check" | jsonfilter -e '@.warnings[0]' 2>/dev/null || true)"
	updated_at="$(TZ=CST-8 date '+%Y-%m-%d %H:%M:%S CST')"

	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_ip=$best_ip"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_port=$best_port"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_speed=$best_speed"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_latency=$best_latency"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_loss=$best_loss"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_colo=$best_colo"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_result_file=$result_file"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_route_interface=$route_interface"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_egress_ip=$egress_ip"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_proxy_suspected=$proxy_suspected"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_warning=$warning"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_updated_at=$updated_at"
	uci set "${CONFIG}.${SECTION}.last_result_${ip_version}_record_type=$record_type"
	uci commit "$CONFIG"
}

run_cfst_for_version() {
	ip_version="$1"
	result_file="$2"
	download_url="$3"
	upload_enabled="$4"
	label="$(version_label "$ip_version")"
	ip_file="$(ip_file_for_version "$ip_version")"

	if [ "$ip_version" = "v6" ] && ! has_ipv6_route; then
		log "skip IPv6 test: no IPv6 default route"
		append_summary "IPv6 无可用默认路由，已跳过"
		return 2
	fi
	if [ ! -f "$ip_file" ]; then
		set_status "error" "缺少 ${label} cfst IP 数据文件：$ip_file"
		return 1
	fi

	log "starting ${label} cfst with $ip_file"
	echo "===== ${label} cfst $(date '+%Y-%m-%d %H:%M:%S') =====" >>"$CFST_LOG"
	# 路由器资源有限，参数选择以稳定为主：更多延迟采样、过滤丢包、适度增加下载候选。
	if ! cfst -f "$ip_file" $CFST_STABLE_ARGS -url "$download_url" -o "$result_file" >>"$CFST_LOG" 2>&1; then
		trim_log_file "$CFST_LOG"
		set_status "error" "${label} cfst 执行失败，请查看日志"
		return 1
	fi
	trim_log_file "$CFST_LOG"

	if [ ! -f "$result_file" ]; then
		set_status "error" "${label} cfst 未生成结果文件：$result_file"
		return 1
	fi

	first_ip="$(awk -F',' 'NR==2 { print $1; exit }' "$result_file")"
	direct_check="$(detect_direct "$first_ip" "$ip_version")"
	nodes="$(csv_to_nodes "$result_file")"
	if [ -z "$nodes" ]; then
		set_status "error" "${label} 结果文件中没有可用节点"
		return 1
	fi

	save_result_state "$ip_version" "$result_file" "$direct_check"
	append_summary "${label} 完成，结果：$result_file"
	proxy_suspected="$(printf '%s' "$direct_check" | jsonfilter -e '@.proxy_suspected' 2>/dev/null || true)"
	warnings="$(printf '%s' "$direct_check" | jsonfilter -e '@.warnings[0]' 2>/dev/null || true)"
	if [ "$proxy_suspected" = "true" ]; then
		ANY_PROXY_SUSPECTED="1"
		if [ -n "$warnings" ]; then
			WARNING_SUMMARY="${WARNING_SUMMARY}${WARNING_SUMMARY:+; }${label}: $warnings"
		fi
	fi

	if [ "$upload_enabled" != "1" ]; then
		log "${label} test complete, upload disabled"
		return 0
	fi

	payload_file="${WORKDIR}/upload-${ip_version}.json"
	cat > "$payload_file" <<EOF
{
  "nickname": "$(printf '%s' "$nickname" | json_escape)",
  "device_id": "$(printf '%s' "$device_id" | json_escape)",
  "device_token": "$(printf '%s' "$device_token" | json_escape)",
  "device_name": "$(get_hostname | json_escape)",
  "ip_version": "$ip_version",
  "direct_check": $direct_check,
  "nodes": [$nodes]
}
EOF

	response="$(curl -fsS -X POST "${WORKER_URL}/api/public/upload" -H "Content-Type: application/json" --data-binary "@${payload_file}")"
	ok="$(printf '%s' "$response" | jsonfilter -e '@.success' 2>/dev/null || true)"
	if [ "$ok" != "true" ]; then
		set_status "error" "${label} 上传失败：$response"
		return 1
	fi

	new_device_id="$(printf '%s' "$response" | jsonfilter -e '@.device_id' 2>/dev/null || true)"
	new_device_token="$(printf '%s' "$response" | jsonfilter -e '@.device_token' 2>/dev/null || true)"
	if [ -n "$new_device_id" ] && [ -n "$new_device_token" ]; then
		uci set "${CONFIG}.${SECTION}.device_id=$new_device_id"
		uci set "${CONFIG}.${SECTION}.device_token=$new_device_token"
		uci commit "$CONFIG"
		device_id="$new_device_id"
		device_token="$new_device_token"
	fi

	log "${label} upload success"
	return 0
}

run_once() {
	require_command curl
	require_command ip
	require_command awk
	require_command jsonfilter
	require_command cfst

	enabled="$(cfg enabled 0)"
	if [ "$enabled" != "1" ]; then
		log "client disabled"
		exit 0
	fi

	upload_enabled="$(cfg upload_enabled 1)"
	ip_mode="$(cfg ip_mode v4)"
	case "$ip_mode" in
		dual) test_versions="v4 v6" ;;
		*) test_versions="v4" ;;
	esac

	device_id="$(cfg device_id)"
	device_token="$(cfg device_token)"
	nickname="$(cfg nickname)"
	configured_result_file="$(cfg result_file "${WORKDIR}/result.csv")"
	download_url="$(cfg download_url "$DEFAULT_DOWNLOAD_URL")"

	if [ "$upload_enabled" = "1" ]; then
		if { [ -n "$device_id" ] && [ -z "$device_token" ]; } || { [ -z "$device_id" ] && [ -n "$device_token" ]; }; then
			set_status "error" "设备凭据不完整，请清空 device_id/device_token 后重新注册。"
			exit 1
		fi
	fi

	if [ "$upload_enabled" = "1" ] && [ -z "$device_id" ] && [ -z "$nickname" ]; then
		set_status "error" "上传模式需要先填写昵称，或先完成注册。"
		exit 1
	fi

	mkdir -p "$WORKDIR"
	cd "$WORKDIR"
	if ! recover_stale_run; then
		set_status "running" "已有测速任务正在运行，请稍后再试。"
		exit 0
	fi
	if ! mkdir "$LOCK_DIR" 2>/dev/null; then
		set_status "running" "已有测速任务正在运行，请稍后再试。"
		exit 0
	fi
	echo "$$" > "$LOCK_DIR/pid"
	trap 'cleanup_run' EXIT INT TERM HUP

	: > "$CFST_LOG"
	clear_result_state
	stop_active_proxy_services
	stopped_proxies="$(stopped_proxy_summary)"

	ANY_PROXY_SUSPECTED="0"
	WARNING_SUMMARY=""
	RESULT_SUMMARY=""
	success_count=0
	failed=0
	for ip_version in $test_versions; do
		result_file="$(result_file_for_version "$configured_result_file" "$ip_version")"
		if run_cfst_for_version "$ip_version" "$result_file" "$download_url" "$upload_enabled"; then
			success_count=$((success_count + 1))
		else
			code="$?"
			if [ "$code" != "2" ]; then
				failed=1
			fi
		fi
	done

	if [ "$failed" = "1" ]; then
		exit 1
	fi
	if [ "$success_count" -eq 0 ]; then
		set_status "error" "没有完成任何测速任务。${RESULT_SUMMARY}"
		exit 1
	fi

	if [ "$upload_enabled" = "1" ]; then
		action_message="上传成功"
	else
		action_message="自用模式：测速完成，未上传"
	fi

	if [ -n "$stopped_proxies" ]; then
		restore_proxy_services
		log "proxy services restored after test: $stopped_proxies"
	fi

	if [ "$ANY_PROXY_SUSPECTED" = "1" ]; then
		set_status "ok" "${action_message}；当前出口疑似代理，上传数据不会参与 DNS 优选。${WARNING_SUMMARY:+ 原因：$WARNING_SUMMARY} ${RESULT_SUMMARY}"
	elif [ -n "$stopped_proxies" ]; then
		set_status "ok" "${action_message}；测速期间已临时暂停代理服务，完成后已恢复。${RESULT_SUMMARY}"
	else
		set_status "ok" "${action_message}。${RESULT_SUMMARY}"
	fi
	log "run complete"
}

run_background() {
	enabled="$(cfg enabled 0)"
	upload_enabled="$(cfg upload_enabled 1)"
	ip_mode="$(cfg ip_mode v4)"
	if [ "$enabled" != "1" ]; then
		set_status "error" "客户端未启用，请先打开启用开关并保存。"
		exit 1
	fi
	if [ -d "$LOCK_DIR" ]; then
		set_status "running" "已有测速任务正在运行，请稍后刷新状态。"
		echo "already running"
		return 0
	fi
	if [ "$upload_enabled" = "1" ]; then
		upload_text="完成后会上传公开众测数据"
	else
		upload_text="自用模式，完成后不会上传"
	fi
	if [ "$ip_mode" = "dual" ]; then
		mode_text="IPv4+IPv6"
	else
		mode_text="IPv4"
	fi
	set_status "running" "后台测速任务已启动：${mode_text}，${upload_text}。测速期间会临时暂停代理服务，完成后自动恢复。"
	rm -f "$BACKGROUND_PID"
	start-stop-daemon -S -b -m -p "$BACKGROUND_PID" -x /bin/sh -- -c "exec /usr/bin/cf-ip-speed-client run > '$BACKGROUND_LOG' 2>&1 < /dev/null"
	echo "started background task"
}

install_cron() {
	enabled="$(cfg enabled 0)"
	schedule_mode="$(cfg schedule_mode interval)"
	interval_hours="$(cfg interval_hours 6)"
	daily_hour="$(cfg daily_hour 3)"
	daily_minute="$(cfg daily_minute 0)"
	log_clear_interval="$(cfg log_clear_interval weekly)"
	sed -i "\|# cf-ip-speed-client|d" /etc/crontabs/root 2>/dev/null || true
	if [ "$enabled" = "1" ]; then
		case "$schedule_mode" in
			daily)
				daily_hour="$(printf '%s' "$daily_hour" | sed 's/[^0-9]//g')"
				daily_minute="$(printf '%s' "$daily_minute" | sed 's/[^0-9]//g')"
				[ -n "$daily_hour" ] || daily_hour=3
				[ -n "$daily_minute" ] || daily_minute=0
				if [ "$daily_hour" -gt 23 ] 2>/dev/null; then daily_hour=3; fi
				if [ "$daily_minute" -gt 59 ] 2>/dev/null; then daily_minute=0; fi
				echo "${daily_minute} ${daily_hour} * * * /usr/bin/cf-ip-speed-client run # cf-ip-speed-client" >> /etc/crontabs/root
				;;
			*)
				interval_hours="$(printf '%s' "$interval_hours" | sed 's/[^0-9]//g')"
				[ -n "$interval_hours" ] || interval_hours=6
				if [ "$interval_hours" -lt 1 ] 2>/dev/null; then interval_hours=6; fi
				if [ "$interval_hours" -gt 168 ] 2>/dev/null; then interval_hours=168; fi
				echo "0 */${interval_hours} * * * /usr/bin/cf-ip-speed-client run # cf-ip-speed-client" >> /etc/crontabs/root
				;;
		esac
	fi
	case "$log_clear_interval" in
		daily)
			echo "15 4 * * * /usr/bin/cf-ip-speed-client clear-log # cf-ip-speed-client-log" >> /etc/crontabs/root
			;;
		weekly)
			echo "20 4 * * 0 /usr/bin/cf-ip-speed-client clear-log # cf-ip-speed-client-log" >> /etc/crontabs/root
			;;
		monthly)
			echo "25 4 1 * * /usr/bin/cf-ip-speed-client clear-log # cf-ip-speed-client-log" >> /etc/crontabs/root
			;;
	esac
	/etc/init.d/cron reload >/dev/null 2>&1 || true
	set_status "ok" "定时任务已更新"
}

case "${1:-run}" in
	register) register_device ;;
	run) run_once ;;
	run-background) run_background ;;
	cron) install_cron ;;
	show-log) show_logs ;;
	clear-log) clear_logs ;;
	*) echo "Usage: $0 {register|run|run-background|cron|show-log|clear-log}" >&2; exit 1 ;;
esac
